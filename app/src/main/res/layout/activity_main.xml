<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_command_panel"
    android:padding="20dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:text="@string/title"
        android:textAllCaps="true"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/subtitle"
        android:textColor="#C7D2B6"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_status_chip"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:text="@string/ready_message"
        android:textColor="#F4F1D0"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/airRaidButton"
        style="@style/Widget.WarSound.Button"
        android:text="@string/air_raid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/radioButton"
        style="@style/Widget.WarSound.Button"
        android:layout_marginTop="12dp"
        android:text="@string/radio_chatter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/airRaidButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/alarmButton"
        style="@style/Widget.WarSound.Button"
        android:layout_marginTop="12dp"
        android:text="@string/battle_alarm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/radioButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/marchButton"
        style="@style/Widget.WarSound.Button"
        android:layout_marginTop="12dp"
        android:text="@string/march_beat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alarmButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/morseButton"
        style="@style/Widget.WarSound.Button"
        android:layout_marginTop="12dp"
        android:text="@string/morse_signal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/marchButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/stopButton"
        style="@style/Widget.WarSound.StopButton"
        android:layout_marginTop="20dp"
        android:text="@string/stop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/morseButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
