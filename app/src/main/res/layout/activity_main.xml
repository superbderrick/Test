<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_command_panel"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="26dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:text="@string/title"
            android:textAllCaps="true"
            android:textColor="@color/war_text"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:text="@string/subtitle"
            android:textAllCaps="true"
            android:textColor="@color/war_text_dim"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="==*=="
            android:textColor="@color/war_text_dim"
            android:textSize="22sp" />

        <LinearLayout
            android:id="@+id/statusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_status_chip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_badge_circle"
                android:backgroundTint="@color/war_green" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/status_idle"
                android:textColor="@color/war_green"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/airRaidButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_air"
                android:textColor="@color/war_text_dim"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/air_raid"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/radioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_radio"
                android:textColor="@color/war_text_dim"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/radio_chatter"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/alarmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_alarm"
                android:textColor="@color/war_text_dim"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/battle_alarm"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/marchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_march"
                android:textColor="@color/war_text_dim"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/march_beat"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/morseButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_morse"
                android:textColor="@color/war_text_dim"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/morse_signal"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/attentionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_attention"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/attention_call"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/holdButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_hold"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/hold_position"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/evacButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_evac"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/evac_signal"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/droneHoverButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_hover"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/drone_hover"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/droneApproachButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_approach"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/drone_approach"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/droneSwarmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_signal_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/badge_swarm"
                android:textColor="@color/war_text_dim"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/drone_swarm"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_stop_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_badge_circle"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="[]"
                android:textColor="@color/war_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="@string/stop"
                android:textColor="@color/war_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
