<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#7E1F16"
                android:startColor="#A33227" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#47120F" />
        </shape>
    </item>
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#D66E65" />
        </shape>
    </item>
</layer-list>
